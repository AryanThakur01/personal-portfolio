#!/usr/bin/env sh

commit_msg=$(cat "$1")
pattern='^(feat|fix|docs|style|refactor|test|chore|perf|ci|revert|update|merge)\([a-z0-9/-]+\): .{1,72}$'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Invalid commit message format."
  echo ""
  echo "   Expected: <type>(<scope>): <description>"
  echo "   Example:  feat: add login page"
  echo "             fix(auth): resolve token expiry"
  echo ""
  echo "   Allowed types: feat fix docs style refactor test chore perf ci revert"
  echo ""
  exit 1
fi
